---
const { frontmatter } = Astro.props;
import Layout from "./Layout.astro";
---

<Layout title={`${frontmatter.title} — Anjelica`} sidebar={false}>
  <article class="project-article">
    <header class="project-header">
      <div class="project-meta">
        <time>{frontmatter.date}</time>
        {frontmatter.tags && (
          <div class="project-tags">
            {frontmatter.tags.map((tag: string) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
      </div>
      <h1>{frontmatter.title}</h1>
      <p class="project-description">{frontmatter.description}</p>
      {frontmatter.github && (
        <a href={frontmatter.github} target="_blank" class="github-link">
          View on GitHub &rarr;
        </a>
      )}
    </header>

    {frontmatter.image && (
      <div class="project-hero">
        <img src={frontmatter.image} alt={frontmatter.title} />
      </div>
    )}

    <div class="project-content">
      <slot />
    </div>
  </article>
</Layout>

<style>
  .project-header { margin-bottom: 2.5rem; }
  .project-meta { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; margin-bottom: 0.75rem; }
  time { color: var(--color-text-muted); font-size: 0.9rem; }
  .project-tags { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .tag { background: var(--color-tag-bg); color: var(--color-text-muted); padding: 0.2rem 0.65rem; border-radius: 99px; font-size: 0.8rem; font-weight: 500; }
  h1 { font-family: var(--font-display); font-size: 2.25rem; line-height: 1.2; margin-bottom: 0.75rem; font-weight: 400; }
  .project-description { color: var(--color-text-muted); font-size: 1.1rem; line-height: 1.6; margin-bottom: 1rem; }
  .github-link { display: inline-block; font-weight: 500; font-size: 0.95rem; }
  .project-hero { margin-bottom: 2.5rem; border-radius: 8px; overflow: hidden; border: 1px solid var(--color-border); }
  .project-hero img { display: block; width: 100%; }
  .project-content { line-height: 1.8; }
  .project-content :global(h2) { font-family: var(--font-display); font-size: 1.5rem; margin-top: 2.5rem; margin-bottom: 0.75rem; font-weight: 400; }
  .project-content :global(h3) { font-size: 1.15rem; font-weight: 700; margin-top: 2rem; margin-bottom: 0.5rem; }
  .project-content :global(p) { margin-bottom: 1.25rem; }
  .project-content :global(ul), .project-content :global(ol) { margin-bottom: 1.25rem; padding-left: 1.5rem; }
  .project-content :global(li) { margin-bottom: 0.35rem; }
  .project-content :global(code) { background: var(--color-tag-bg); padding: 0.15rem 0.4rem; border-radius: 4px; font-size: 0.9em; }
  .project-content :global(pre) { background: #1a1a1a; color: #e5e5e5; padding: 1.25rem; border-radius: 8px; overflow-x: auto; margin-bottom: 1.5rem; font-size: 0.9rem; line-height: 1.6; }
  .project-content :global(pre code) { background: none; padding: 0; color: inherit; }
  .project-content :global(blockquote) { border-left: 3px solid var(--color-accent); padding-left: 1rem; color: var(--color-text-muted); margin-bottom: 1.25rem; font-style: italic; }
  .project-content :global(img) { border-radius: 8px; border: 1px solid var(--color-border); margin: 1.5rem 0; }

  @media (max-width: 600px) {
    h1 { font-size: 1.75rem; }
  }
</style>

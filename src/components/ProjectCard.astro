---
interface Props {
  title: string;
  description: string;
  href: string;
  tags?: string[];
  date?: string;
  image?: string;
  color?: string;
}

const { title, description, href, tags = [], date, image, color = "#65a30d" } = Astro.props;
---

<a href={href} class="project-card">
  <div class="card-thumb" style={image ? `background-image: url(${image});` : `background: linear-gradient(135deg, ${color}, ${color}dd);`}>
    {!image && <span class="card-thumb-title">{title}</span>}
  </div>
  <div class="card-content">
    <div class="card-top">
      {date && <time>{date}</time>}
      {tags.length > 0 && (
        <div class="card-tags">
          {tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </div>
    <h3>{title}</h3>
    <p>{description}</p>
    <span class="read-more">Read more &rarr;</span>
  </div>
</a>

<style>
  .project-card {
    display: block;
    background: var(--color-card-bg);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
  }

  .project-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 4px 20px rgba(101, 163, 13, 0.1);
    transform: translateY(-2px);
  }

  .card-thumb {
    height: 160px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    background-size: cover;
    background-position: center;
  }

  .card-thumb-title {
    color: #ffffff;
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 400;
    text-align: center;
    line-height: 1.3;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.15);
  }

  .card-content {
    padding: 1.25rem 1.5rem 1.5rem;
  }

  .card-top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
  }

  time { color: var(--color-text-muted); font-size: 0.85rem; }
  .card-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; }
  .tag { background: var(--color-tag-bg); color: var(--color-text-muted); padding: 0.15rem 0.55rem; border-radius: 99px; font-size: 0.75rem; font-weight: 500; }
  h3 { font-family: var(--font-display); font-size: 1.2rem; font-weight: 400; margin-bottom: 0.4rem; line-height: 1.3; }
  p { color: var(--color-text-muted); font-size: 0.9rem; line-height: 1.6; margin-bottom: 0.75rem; }
  .read-more { color: var(--color-accent); font-size: 0.9rem; font-weight: 500; }
  .project-card:hover .read-more { color: var(--color-accent-hover); }
</style>

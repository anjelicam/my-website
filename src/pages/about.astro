---
import Layout from "../layouts/Layout.astro";

const base = import.meta.env.BASE_URL;
---

<Layout title="About — Anjelica Martinez" sidebar={true}>
  <div class="about-page">
    <h1>About Me</h1>

    <div class="about-content">
      <p>
        Hi! I'm Anjelica Martinez, a data science student passionate about
        using data to make a real-world impact. I love working at the intersection
        of data and the things I care about most — gaming, music & audio,
        health & wellness, environmental sustainability, and animal welfare.
      </p>

      <p>
        My work spans machine learning, data analysis, and visualization. I enjoy
        the full process — from cleaning messy datasets to building models to
        communicating results in a way that tells a story.
      </p>

      <h2>What I'm Working On</h2>
      <p>
        Right now I'm focused on building out my data science portfolio with
        projects that reflect both my technical skills and my interests. I'm
        particularly drawn to startups and mission-driven organizations where
        data science can create meaningful change.
      </p>

      <h2>Skills & Tools</h2>
      <p>
        Python (pandas, scikit-learn, matplotlib), R, SQL, Jupyter Notebooks,
        Git & GitHub, machine learning (classification, regression,
        cross-validation), data visualization, and statistical analysis.
      </p>

      <h2>Get in Touch</h2>
      <p>
        I'm always open to connecting! You can find me on
        <a href="https://github.com/anjelicam" target="_blank">GitHub</a> and
        <a href="https://linkedin.com/in/YOUR-LINKEDIN" target="_blank">LinkedIn</a>,
        or reach me by email at
        <a href="mailto:your@email.com">your@email.com</a>.
      </p>
    </div>
  </div>
</Layout>

<style>
  .about-page {
    padding-top: 1rem;
  }

  h1 {
    font-family: var(--font-display);
    font-size: 2.25rem;
    font-weight: 400;
    margin-bottom: 1.5rem;
    line-height: 1.2;
  }

  .about-content p {
    margin-bottom: 1.25rem;
    line-height: 1.8;
    color: var(--color-text);
  }

  .about-content h2 {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 400;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .about-content a {
    color: var(--color-accent);
    font-weight: 500;
  }

  .about-content a:hover {
    color: var(--color-accent-hover);
  }
</style>

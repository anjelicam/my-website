---
import Layout from "../layouts/Layout.astro";

const base = import.meta.env.BASE_URL;

const projects = [
  {
    title: "Earthquake Damage Classification",
    href: `${base}projects/earthquake-classification`,
    tags: ["Machine Learning", "Python"],
    image: `${base}/images/placeholder.jpg`,
  },
  {
    title: "Banned Books Analysis",
    href: `${base}projects/banned-books`,
    tags: ["Data Analysis", "R"],
    image: `${base}/images/banned_books.webp`,
  },
  {
    title: "Shelter Stories in the Data",
    href: `${base}/projects/aac-repeat-pets`,
    tags: ["Visualization", "Python"],
    image: `${base}/images/animal_shelter.jpg`,
  },
  {
    title: "Project Four Title",
    href: `${base}projects/project-four`,
    tags: ["NLP", "Python"],
    image: `${base}/images/placeholder.jpg`,
  },
];
---

<Layout title="Anjelica Martinez — Portfolio">
  <div class="mosaic">
    {projects.map((project) => (
      <a href={project.href} class="mosaic-card">
        <div class="card-image" style={`background-image: url(${project.image});`}>
          <div class="card-overlay">
            <h2>{project.title}</h2>
          </div>
        </div>
        <div class="card-footer">
          {project.tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      </a>
    ))}
  </div>
</Layout>

<style>
  .mosaic {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1.25rem;
  }

  .mosaic-card {
    text-decoration: none;
    color: inherit;
    border-radius: 10px;
    overflow: hidden;
    background: var(--color-card-bg);
    border: 1px solid var(--color-border);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .mosaic-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 28px rgba(101, 163, 13, 0.1);
    border-color: var(--color-accent-hover);
  }

  .card-image {
    aspect-ratio: 4 / 3;
    background-size: cover;
    background-position: center;
    background-color: var(--color-tag-bg);
    position: relative;
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.65) 0%, rgba(0,0,0,0) 55%);
    display: flex;
    align-items: flex-end;
    padding: 1rem 1.1rem;
  }

  .card-overlay h2 {
    color: #fff;
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 400;
    line-height: 1.3;
    text-shadow: 0 1px 3px rgba(0,0,0,0.3);
  }

  .card-footer {
    padding: 0.65rem 1rem;
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .tag {
    background: var(--color-tag-bg);
    color: var(--color-text-muted);
    padding: 0.15rem 0.55rem;
    border-radius: 99px;
    font-size: 0.75rem;
    font-weight: 500;
  }

  @media (max-width: 540px) {
    .mosaic {
      grid-template-columns: 1fr;
    }
  }
</style>
